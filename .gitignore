# Anything that looks like an API key file
*api_key*
*api-key*
*apikey*

# ─────────────────────────────── model checkpoints ────────────────────
# BERTurk and XLM-R weights are big (442 MB and 1 GB). They are reproducible
# from colab_notebook.ipynb (~3-5 min on a Colab T4), so don't bloat git
# with them. If you want to ship them, use Git LFS or upload to a separate
# release / Drive folder and link from README.
*.pt
*.pth
*.safetensors
*.onnx
*.h5

# Allow tokenizer files (small; needed for the demo to start without
# downloading from HF Hub on the cold path)
!outputs/berturk_emotion/tokenizer/**

# ─────────────────────────────── generated outputs ────────────────────
# Note: outputs/ is INTENTIONALLY tracked (small json/csv/png artefacts
# that document the experiment results referenced in the report). Only the
# big model checkpoints inside it are excluded via the *.bin rule above.
#
# If you'd rather not track ANY generated outputs and let users regenerate
# from the notebook, uncomment:
# outputs/

# Streamlit's local on-disk LLM cache CAN balloon; keep but cap by re-running
# rather than ignoring (it's the experiment's reproducibility anchor)

# ─────────────────────────────── misc ─────────────────────────────────
*.log
*.tmp
*.bak
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/
